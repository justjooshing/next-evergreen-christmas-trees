---
import { ClientRouter } from 'astro:transitions';
import Header from '../components/utils/Header.astro';
import Footer from '../components/utils/Footer.astro';
import { metaTags } from '../lib/constants';
import { schema } from '../../constants/headerData';
import '../styles/globals.scss';

interface Props {
  pageName: string;
}

const { pageName } = Astro.props;

const {
  Global: { siteName },
} = metaTags;

const isNoIndex = pageName === 'admin' || pageName === '404 - Not Found';
const pageMetaData = metaTags[pageName as keyof typeof metaTags];
const description =
  pageMetaData && 'description' in pageMetaData
    ? pageMetaData.description
    : undefined;

const canonicalUrl = Astro.url.href;
const schemaJson = JSON.stringify(schema);
---

<!doctype html>
<html lang="en-AU">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {isNoIndex ? (
      <>
        <meta name="robots" content="noindex, nofollow" />
        <title>{pageName}</title>
      </>
    ) : (
      <>
        <meta name="robots" content="index, follow" />

        <title>{`${pageName} - ${siteName}`}</title>
        <meta property="og:title" content={`${pageName} - ${siteName}`} />
        {description && <meta name="description" content={description} />}
        {description && <meta property="og:description" content={description} />}

        <meta property="og:site_name" content={siteName} />
        <meta property="og:image" content="/slideshow_images/index/IMG_5249.jpg" />
        <meta property="og:image:alt" content="Evergreen Christmas Trees Sign" />
        <meta property="og:url" content={canonicalUrl} />
        <meta property="og:locale" content="en_AU" />
        <link rel="canonical" href={canonicalUrl} />

        <script type="application/ld+json" set:html={schemaJson} />
      </>
    )}

    <!-- Favicons / web app manifest -->
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="mask-icon" href="/safari-pinned-tab.svg" color="#184d00" />

    <ClientRouter />
  </head>
  <body>
    <div id="page-wrapper">
      <Header pageName={pageName} />
      <main class="layout-main">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>

<style is:global>
  body {
    background-color: rgb(24, 77, 0);
  }

  #page-wrapper {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  .layout-main {
    flex: 1;
    padding: 0.5em;
    background: linear-gradient(
      180deg,
      rgb(24, 77, 0) 25%,
      rgb(21, 66, 0),
      80%,
      rgb(19, 40, 0)
    );
  }
</style>
