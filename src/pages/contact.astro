---
import Layout from '../layouts/Layout.astro';
import ContactDetails from '../components/atom/ContactDetails.astro';
import MapWrapper from '../components/atom/MapWrapper.astro';
import OpeningHours from '../components/atom/OpeningHours.astro';
import SocialMediaIcons from '../components/atom/SocialMediaIcons.astro';
---

<Layout pageName="Contact">
  <section class="main">
    <MapWrapper />
    <div>
      <OpeningHours />
      <SocialMediaIcons />
      <ContactDetails />
    </div>
  </section>
</Layout>

<style>
  .main {
    display: flex;
    flex-direction: column;
    text-align: center;
    padding: 0.5em 1em;
    place-content: center;
  }

  .main h3 {
    margin-bottom: 0px;
  }

  @media (min-width: 800px) {
    .main {
      flex-direction: row;
    }
  }
</style>
