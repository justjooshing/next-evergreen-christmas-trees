---
import Layout from '../layouts/Layout.astro';
import Slideshow from '../components/molecule/Slideshow.astro';
import SchoolList from '../components/atom/SchoolList.astro';
import { schoolImageAlts } from '../lib/constants';

import imgCornish from '../assets/slideshow_images/community/Cornish_college_2023.jpg';
import imgNepean from '../assets/slideshow_images/community/Nepean_school2020.jpg';
import imgPatterson from '../assets/slideshow_images/community/Patterson_lakes_primary_2023.jpg';
import imgChelsea from '../assets/slideshow_images/community/Chelsea_heights_primary2020.jpg';
import imgAspendale from '../assets/slideshow_images/community/Aspendale_gardens_primary2020.jpg';
import imgEdithvale from '../assets/slideshow_images/community/Edithvale_primary_2023.jpg';
import imgStBrigids from '../assets/slideshow_images/community/St_Brigids_2023.jpg';
import imgStJosephs from '../assets/slideshow_images/community/St_Josephs_2023.jpg';

const rawImages = [imgCornish, imgNepean, imgPatterson, imgChelsea, imgAspendale, imgEdithvale, imgStBrigids, imgStJosephs];
const schoolSlides = rawImages.map((src, i) => ({ src, alt: schoolImageAlts[i].alt, caption: schoolImageAlts[i].caption }));
---

<Layout pageName="Community">
  <section class="main">
    <p>
      We love being involved with and supporting our local community. We
      partner with our local schools and community groups to spread joy each
      Christmas. Here are some photos of our trees at local schools.
    </p>
    <Slideshow slides={schoolSlides} />
    <SchoolList />
  </section>
</Layout>

<style>
  .main {
    display: flex;
    flex-direction: column;
    text-align: center;
    margin: 0em 2em;
  }

  .main > p {
    align-self: center;
    max-width: 80%;
  }
</style>
